{
  "name": "tik-talk",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/tik-talk/src",
  "prefix": "app",
  "generators": {
    "@schematics/angular:component": {
      "style": "scss",
      "skipTests": true
    }
  },
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "options": {
        "outputPath": "dist/apps/tik-talk",
        "index": "apps/tik-talk/src/index.html",
        "browser": "apps/tik-talk/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/tik-talk/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "public"
          }
        ],
        "styles": ["apps/tik-talk/src/styles.scss"],
        "scripts": [],
        "server": "apps/tik-talk/src/main.server.ts",
        "ssr": {
          "entry": "apps/tik-talk/src/server.ts"
        },
        "outputMode": "server"
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "1MB",
              "maximumError": "2MB"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "2kB",
              "maximumError": "4kB"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": []
        }
      },
      "defaultConfiguration": "production",
      "outputs": ["{options.outputPath}"]
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "tik-talk:build:production"
        },
        "development": {
          "buildTarget": "tik-talk:build:development"
        }
      },
      "defaultConfiguration": "development",
      "options": {
        "proxyConfig": "proxy-conf.json"
      }
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n"
    },
    "test": {
      "executor": "@angular-devkit/build-angular:karma",
      "options": {
        "polyfills": ["zone.js", "zone.js/testing"],
        "tsConfig": "apps/tik-talk/tsconfig.spec.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/tik-talk/public"
          }
        ],
        "styles": ["apps/tik-talk/src/styles.scss"],
        "scripts": []
      }
    }
  }
}
